<Window x:Class="WpfApp3.AddEditStudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Студент" Height="450" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Фамилия:" Margin="0,5,0,0"/>
            <TextBox x:Name="tbLastName" Margin="0,0,0,10"/>
            
            <TextBlock Text="Имя:" Margin="0,0,0,0"/>
            <TextBox x:Name="tbFirstName" Margin="0,0,0,10"/>
            
            <TextBlock Text="Отчество:" Margin="0,0,0,0"/>
            <TextBox x:Name="tbPatronymic" Margin="0,0,0,10"/>
            
            <TextBlock Text="Пол:" Margin="0,0,0,0"/>
            <ComboBox x:Name="cbGender" Margin="0,0,0,10">
                <ComboBoxItem Content="Мужской"/>
                <ComboBoxItem Content="Женский"/>
            </ComboBox>

            <TextBlock Text="Группа (ID):" Margin="0,0,0,0"/>
            <TextBox x:Name="tbGroupID" Margin="0,0,0,10"/>

            <TextBlock Text="Email:" Margin="0,0,0,0"/>
            <TextBox x:Name="tbEmail" Margin="0,0,0,10"/>

            <Button Content="Сохранить" Background="#007ACC" Foreground="White" Padding="10,5" Margin="0,15,0,0" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>