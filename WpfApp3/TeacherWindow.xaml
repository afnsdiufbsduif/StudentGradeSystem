<Window x:Class="WpfApp3.TeacherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель Преподавателя" Height="650" Width="1000" Background="#F0F4F8" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="#E1E5EA"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Foreground" Value="#107C41"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D9E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EAEAEA"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFC"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#107C41" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Рабочее место преподавателя" FontSize="26" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <Button Content="Выйти из системы" Grid.Column="1" Background="#D13438" Foreground="White" HorizontalAlignment="Right" Click="BtnLogout_Click"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="15" BorderBrush="#D1D9E6" BorderThickness="1">
            
            <!-- Вкладка: Журнал оценок -->
            <TabItem Header="Журнал оценок">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbGradeGroup" Width="140" VerticalContentAlignment="Center" Margin="0,0,15,0" DisplayMemberPath="GroupName" SelectionChanged="CbGradeGroup_SelectionChanged"/>
                        
                        <TextBlock Text="Предмет:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbGradeSubject" Width="200" VerticalContentAlignment="Center" Margin="0,0,20,0" DisplayMemberPath="SubjectName" SelectionChanged="CbGradeSubject_SelectionChanged"/>

                        <Button Content="➕ Выставить оценку" Click="BtnAddGrade_Click"/>
                        <Button Content="✏️ Изменить" Background="#2B88D8" Click="BtnEditGrade_Click"/>
                        <Button Content="❌ Удалить" Background="#D13438" Click="BtnDeleteGrade_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgGrades" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Студент" Binding="{Binding FullName}" Width="250"/>
                            <DataGridTextColumn Header="Оценка" Binding="{Binding GradeValue}" Width="100"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="120"/>
                            <DataGridTextColumn Header="Тип (Лекция/Прак.)" Binding="{Binding Type}" Width="150"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Посещаемость -->
            <TabItem Header="Посещаемость">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbAttendanceGroup" Width="140" VerticalContentAlignment="Center" Margin="0,0,15,0" DisplayMemberPath="GroupName" SelectionChanged="CbAttendanceGroup_SelectionChanged"/>

                        <TextBlock Text="Предмет:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbAttendanceSubject" Width="180" VerticalContentAlignment="Center" Margin="0,0,15,0" DisplayMemberPath="SubjectName" SelectionChanged="CbAttendanceSubject_SelectionChanged"/>
                        
                        <TextBlock Text="Дата занятия:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <DatePicker x:Name="dpAttendanceDate" Width="150" VerticalContentAlignment="Center" Margin="0,0,20,0" SelectedDateChanged="DpAttendanceDate_SelectedDateChanged"/>

                        <Button Content="Обновить список" Background="#605E5C" Click="BtnUpdateAttendance_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgAttendance" Grid.Row="1" AutoGenerateColumns="False" Margin="0,0,0,15">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Студент" Binding="{Binding FullName}" Width="300" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Присутствие (Отметить если был)" Binding="{Binding IsPresent}" Width="250"/>
                            <DataGridTextColumn Header="Причина отсутствия (если есть)" Binding="{Binding Reason}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="💾 Сохранить посещаемость" Background="#107C41" Padding="20,10" Click="BtnSaveAttendance_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Мои студенты -->
            <TabItem Header="Список студентов">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Группа:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbTeacherStudentGroup" Width="140" VerticalContentAlignment="Center" Margin="0,0,15,0" DisplayMemberPath="GroupName"/>
                        <TextBox x:Name="tbTeacherStudentSearch" Width="250" Margin="10,5,5,5" Text="Поиск по ФИО..." Foreground="Gray" VerticalContentAlignment="Center" Padding="5,0"/>
                        <Button Content="🔍 Найти" Background="#605E5C" Click="BtnSearchTeacherStudent_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="dgStudents" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding StudentID}" Width="60"/>
                            <DataGridTextColumn Header="ФИО Студента" Binding="{Binding FullName}" Width="300"/>
                            <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="120"/>
                            <DataGridTextColumn Header="Email / Контакт" Binding="{Binding Contact}" Width="250"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Отчеты -->
            <TabItem Header="Отчеты (Успеваемость и Пропуски)">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Тип отчета:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15" FontWeight="SemiBold" Foreground="#333"/>
                        <ComboBox x:Name="cbTeacherReportType" Width="280" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,15,0" Padding="10,5">
                            <ComboBoxItem Content="Текущая успеваемость группы"/>
                            <ComboBoxItem Content="Итоговые оценки за экзамены"/>
                            <ComboBoxItem Content="Отчет по пропускам студентов"/>
                        </ComboBox>
                        <Button Content="📄 Сгенерировать" Background="#107C41" Click="BtnGenerateReport_Click"/>
                        <Button Content="📥 Экспорт в Excel" Background="#217346" Click="BtnExportExcel_Click"/>
                    </StackPanel>
                    
                    <Border Grid.Row="1" BorderBrush="#D1D9E6" BorderThickness="1" Background="#F9FAFC" Padding="20">
                        <TextBlock Text="📊 Выберите тип отчета и группу, чтобы получить информацию о пропусках и успеваемости студентов." 
                                   Foreground="#777" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="16" TextAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>
            
        </TabControl>
    </Grid>
</Window>
