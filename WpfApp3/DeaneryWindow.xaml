<Window x:Class="WpfApp3.DeaneryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель Управления Деканата" Height="650" Width="1100" Background="#F0F4F8" WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="#E1E5EA"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Foreground" Value="#004DA0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D9E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EAEAEA"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFC"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#004DA0" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Система Управления: Деканат" FontSize="26" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <Button Content="Выйти из системы" Grid.Column="1" Background="#D13438" Foreground="White" HorizontalAlignment="Right" Click="BtnLogout_Click"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="15" BorderBrush="#D1D9E6" BorderThickness="1">

            <!-- Вкладка: Студенты -->
            <TabItem Header="Студенты">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button Content="➕ Добавить студента" Click="BtnAddStudent_Click"/>
                        <Button Content="✏️ Редактировать" Background="#2B88D8" Click="BtnEditStudent_Click"/>
                        <Button Content="❌ Удалить" Background="#D13438" Click="BtnDeleteStudent_Click"/>
                        <TextBox x:Name="tbSearchStudent" Width="250" Margin="30,5,5,5" Text="Поиск по ФИО или Группе..." Foreground="Gray" VerticalContentAlignment="Center" Padding="5,0" GotFocus="TbSearchStudent_GotFocus" LostFocus="TbSearchStudent_LostFocus"/>
                        <Button Content="🔍 Найти" Background="#605E5C" Click="BtnSearchStudent_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="dgStudents" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding StudentID}" Width="60"/>
                            <DataGridTextColumn Header="ФИО Студента" Binding="{Binding FullName}" Width="300"/>
                            <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="120"/>
                            <DataGridTextColumn Header="Специальность" Binding="{Binding Speciality}" Width="250"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Преподаватели -->
            <TabItem Header="Преподаватели">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="63*"/>
                        <ColumnDefinition Width="260*"/>
                        <ColumnDefinition Width="711*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15" Grid.ColumnSpan="3">
                        <Button Content="➕ Добавить преподавателя" Click="BtnAddTeacher_Click"/>
                        <Button Content="✏️ Редактировать" Background="#2B88D8" Click="BtnEditTeacher_Click"/>
                        <Button Content="❌ Удалить" Background="#D13438" Click="BtnDeleteTeacher_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="dgTeachers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Grid.ColumnSpan="3">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding TeacherID}" Width="60"/>
                            <DataGridTextColumn Header="ФИО Преподавателя" Binding="{Binding FullName}" Width="300"/>
                            <DataGridTextColumn Header="Кафедра" Binding="{Binding Department}" Width="250"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Группы и Предметы -->
            <TabItem Header="Группы и Распределение">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0">
                        <TextBlock Text="Учебные Группы" DockPanel.Dock="Top" FontSize="18" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,15,0,0">
                            <Button Content="➕ Добавить" Click="BtnAddGroup_Click"/>
                            <Button Content="❌ Удалить" Background="#D13438" Click="BtnDeleteGroup_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="dgGroups" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Группа" Binding="{Binding GroupName}" Width="120"/>
                                <DataGridTextColumn Header="Курс" Binding="{Binding Course}" Width="80"/>
                                <DataGridTextColumn Header="Студентов" Binding="{Binding StudentCount}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <DockPanel Grid.Column="2">
                        <TextBlock Text="Предметы и Назначения преподавателей" DockPanel.Dock="Top" FontSize="18" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,10"/>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,15,0,0">
                            <Button Content="🔗 Назначить преподавателя" Click="BtnAssignTeacher_Click"/>
                        </StackPanel>
                        <DataGrid x:Name="dgSubjects" AutoGenerateColumns="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Предмет" Binding="{Binding SubjectName}" Width="300"/>
                                <DataGridTextColumn Header="Часы" Binding="{Binding CreditHours}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- Вкладка: Отчеты -->
            <TabItem Header="Отчеты и Успеваемость">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Тип отчета:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15" FontWeight="SemiBold" Foreground="#333"/>
                        <ComboBox x:Name="cbDeaneryReportType" Width="280" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,15,0" Padding="10,5">
                            <ComboBoxItem Content="Сводный отчет по успеваемости"/>
                            <ComboBoxItem Content="Сводный отчет по посещаемости"/>
                            <ComboBoxItem Content="Результаты сессии"/>
                            <ComboBoxItem Content="Отчет по конкретной группе"/>
                        </ComboBox>
                        <Button Content="📄 Сгенерировать" Background="#107C41" Click="BtnGenerateReport_Click"/>
                        <Button Content="📥 Экспорт в Excel" Background="#217346" Click="BtnExportReport_Click"/>
                        <Button Content="🖨 Печать" Background="#605E5C" Click="BtnPrintReport_Click"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="#D1D9E6" BorderThickness="1" Background="#F9FAFC" Padding="20">
                        <TextBlock Text="📊 Выберите тип отчета и нажмите «Сгенерировать», чтобы получить сводные данные по успеваемости, посещаемости и оценкам студентов." 
                                   Foreground="#777" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="16" TextAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Вкладка: Администрирование (Доступы) -->
            <TabItem Header="Управление доступом">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Аккаунты пользователей" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#333" Margin="0,0,20,0"/>
                        <Button Content="➕ Создать аккаунт" Click="BtnCreateAccount_Click"/>
                        <Button Content="🔑 Сбросить пароль" Background="#E81123" Click="BtnResetPassword_Click"/>
                        <Button Content="🛡 Права доступа" Background="#605E5C" Click="BtnAccessRights_Click"/>
                    </StackPanel>
                    <DataGrid x:Name="dgUsers" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="200"/>
                            <DataGridTextColumn Header="Роль (Student/Teacher/Deanery)" Binding="{Binding Role}" Width="250"/>
                            <DataGridTextColumn Header="Связанный профиль (ID)" Binding="{Binding RecordID}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
