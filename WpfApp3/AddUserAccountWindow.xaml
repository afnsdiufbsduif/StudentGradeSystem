<Window x:Class="WpfApp3.AddUserAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новый аккаунт" Height="400" Width="300" WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Логин:" Margin="0,5,0,0"/>
            <TextBox x:Name="tbLogin" Margin="0,0,0,10"/>
            
            <TextBlock Text="Пароль:" Margin="0,0,0,0"/>
            <TextBox x:Name="tbPassword" Margin="0,0,0,10"/>
            
            <TextBlock Text="Роль:" Margin="0,0,0,0"/>
            <ComboBox x:Name="cbRole" Margin="0,0,0,10">
                <ComboBoxItem Content="Student" IsSelected="True"/>
                <ComboBoxItem Content="Teacher"/>
                <ComboBoxItem Content="Deanery"/>
            </ComboBox>

            <TextBlock Text="StudentID (если студент):" Margin="0,0,0,0"/>
            <TextBox x:Name="tbStudentID" Margin="0,0,0,10"/>
            
            <TextBlock Text="TeacherID (если препод):" Margin="0,0,0,0"/>
            <TextBox x:Name="tbTeacherID" Margin="0,0,0,10"/>
            
            <Button Content="Сохранить" Background="#007ACC" Foreground="White" Padding="10,5" Margin="0,15,0,0" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>