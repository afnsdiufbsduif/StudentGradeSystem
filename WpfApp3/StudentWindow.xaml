<Window x:Class="WpfApp3.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Личный кабинет студента" Height="650" Width="1000" Background="#F0F4F8" WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="15,7"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Background" Value="#E1E5EA"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Foreground" Value="#0078D7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1D9E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowHeight" Value="35"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EAEAEA"/>
            <Setter Property="AlternatingRowBackground" Value="#F9FAFC"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#0078D7" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Личный кабинет студента" FontSize="26" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="Иван Иванов • Группа: ПИ-101" FontSize="14" Foreground="#D0E4F5"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnNotifications" Content="Уведомления" Background="#F39C12" Foreground="White" Margin="0,0,15,0" Padding="15,8" ToolTip="Есть новые оценки" Click="BtnNotifications_Click"/>
                    <Button Content="Выйти из системы" Background="#D13438" Foreground="White" Click="BtnLogout_Click" Padding="15,8"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Margin="15" BorderBrush="#D1D9E6" BorderThickness="1">
            
            <!-- Вкладка: Мои оценки -->
            <TabItem Header="Мои оценки">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Семестр:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbSemester" Width="150" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,15,0">
                            <ComboBoxItem Content="1 Семестр (Осень)"/>
                            <ComboBoxItem Content="2 Семестр (Весна)"/>
                            <ComboBoxItem Content="Все за все время"/>
                        </ComboBox>
                        
                        <TextBlock Text="Предмет:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbGradesSubject" Width="200" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,20,0" DisplayMemberPath="SubjectName"/>

                        <Button Content="Обновить" Background="#605E5C" Click="BtnRefreshGrades_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgGrades" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="250"/>
                            <DataGridTextColumn Header="Преподаватель" Binding="{Binding Teacher}" Width="250"/>
                            <DataGridTextColumn Header="Оценка" Binding="{Binding GradeValue}" Width="100"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="120"/>
                            <DataGridTextColumn Header="Тип работы" Binding="{Binding WorkType}" Width="150"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Посещаемость -->
            <TabItem Header="Посещаемость">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Выборка за:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbAttendancePeriod" Width="150" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,15,0">
                            <ComboBoxItem Content="Этот месяц"/>
                            <ComboBoxItem Content="Прошлый месяц"/>
                            <ComboBoxItem Content="Весь семестр"/>
                        </ComboBox>

                        <TextBlock Text="Предмет:" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="SemiBold"/>
                        <ComboBox x:Name="cbAttendanceSubject" Width="200" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,20,0" DisplayMemberPath="SubjectName"/>

                        <!-- Summary Cards -->
                        <Border Background="#E6F4EA" BorderBrush="#34A853" BorderThickness="1" Padding="15,5" Margin="20,0,0,0" CornerRadius="4">
                            <TextBlock x:Name="tbPresentCount" Text="Присутствий: 0" Foreground="#137333" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Border>
                        <Border Background="#FCE8E6" BorderBrush="#EA4335" BorderThickness="1" Padding="15,5" Margin="10,0,0,0" CornerRadius="4">
                            <TextBlock x:Name="tbAbsentCount" Text="Пропусков: 0" Foreground="#C5221F" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <DataGrid x:Name="dgAttendance" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="120"/>
                            <DataGridTextColumn Header="Предмет" Binding="{Binding Subject}" Width="250"/>
                            <DataGridTextColumn Header="Тип (Лекция/Прак.)" Binding="{Binding Type}" Width="150"/>
                            <DataGridTextColumn Header="Статус (Был / Пропуск)" Binding="{Binding Status}" Width="180"/>
                            <DataGridTextColumn Header="Заметка преподавателя" Binding="{Binding Note}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Вкладка: Отчеты и статистика -->
            <TabItem Header="Моя успеваемость (Отчеты)">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="Скачать справку / отчет:" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="15" FontWeight="SemiBold" Foreground="#333"/>
                        <ComboBox x:Name="cbStudentReportType" Width="280" SelectedIndex="0" VerticalContentAlignment="Center" Margin="0,0,15,0" Padding="10,5">
                            <ComboBoxItem Content="Транскрипт оценок (Pdf)"/>
                            <ComboBoxItem Content="Справка об успеваемости"/>
                            <ComboBoxItem Content="Отчет по посещаемости"/>
                        </ComboBox>
                        <Button Content="📥 Скачать" Background="#217346" Padding="20,8" Click="BtnDownloadReport_Click"/>
                    </StackPanel>
                    
                    <Border Grid.Row="1" BorderBrush="#D1D9E6" BorderThickness="1" Background="#F9FAFC" Padding="20">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="🎓 Мой средний балл (GPA): 4.6" FontSize="22" FontWeight="Bold" Foreground="#0078D7" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Вы можете скачать официальный отчет со своими оценками для предоставления по месту требования или для личного контроля успеваемости." 
                                       Foreground="#777" HorizontalAlignment="Center" TextWrapping="Wrap" FontSize="16" TextAlignment="Center" MaxWidth="600"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
        </TabControl>
    </Grid>
</Window>
